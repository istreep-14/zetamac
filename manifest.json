{
  "manifest_version": 3,
  "name": "Smart Zetamac Coach",
  "version": "1.0",
  "description": "Track your Zetamac performance with detailed analytics and Google Sheets integration",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://arithmetic.zetamac.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://arithmetic.zetamac.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Zetamac Coach Stats"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
